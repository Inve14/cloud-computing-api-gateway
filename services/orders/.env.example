# ============================================================
# Orders Service — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# Runtime environment. Controls log format and dotenv loading.
# Values: development | test | production
NODE_ENV=development

# Port the Fastify HTTP server listens on.
PORT=3003

# Minimum log level.
# Values: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Option A (preferred): a single connection string.
DATABASE_URL=postgresql://orders_user:orders_pass@localhost:5432/orders_db

# Option B: individual parameters (used when DATABASE_URL is not set).
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=orders_db
# DB_USER=orders_user
# DB_PASSWORD=orders_pass

# Connection pool tuning
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=3000

# JWT — public key for RS256 verification
# Used to verify tokens issued by the Users service.
# In Docker: mounted from ./infrastructure/jwt-keys/public.pem
JWT_PUBLIC_KEY_PATH=/etc/jwt-keys/public.pem
