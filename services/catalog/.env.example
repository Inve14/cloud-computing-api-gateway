# ============================================================
# Catalog Service — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# In production, inject these variables at deploy time (GitHub Actions secrets,
# docker-compose environment section, or AWS Secrets Manager).
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Runtime environment. Controls log format and dotenv loading.
# Values: development | test | production
NODE_ENV=development

# Port the Fastify HTTP server listens on.
# Default: 3001 (catalog). Each service uses a different port locally.
PORT=3001

# Minimum log level. In production, prefer "info" or "warn".
# Values: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ------------------------------------------------------------
# Database — primary connection
# ------------------------------------------------------------

# Option A (preferred): a single connection string.
# Overrides all DB_* variables below if set.
DATABASE_URL=postgresql://catalog_user:catalog_pass@localhost:5432/catalog_db

# Option B: individual parameters (used when DATABASE_URL is not set).
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=catalog_db
# DB_USER=catalog_user
# DB_PASSWORD=catalog_pass

# ------------------------------------------------------------
# Database — connection pool tuning
# ------------------------------------------------------------

# Maximum number of clients in the pool (per service replica).
# With 2 replicas this means up to 20 total connections to PostgreSQL.
DB_POOL_MAX=10

# Milliseconds a client can sit idle before being closed.
DB_IDLE_TIMEOUT_MS=30000

# Milliseconds to wait for a new connection before throwing an error.
DB_CONNECTION_TIMEOUT_MS=3000

# ------------------------------------------------------------
# JWT — public key for RS256 verification
# Used to verify tokens issued by the Users service.
# In Docker: mounted from ./infrastructure/jwt-keys/public.pem
# ------------------------------------------------------------
JWT_PUBLIC_KEY_PATH=/etc/jwt-keys/public.pem
