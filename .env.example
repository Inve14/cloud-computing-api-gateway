# =============================================================================
# Root environment variables template for Docker Compose.
# =============================================================================
# Copy this file to .env and set real values before running the stack:
#   cp .env.example .env
#
# .env is excluded from version control (.gitignore).
# In production (EC2), these variables are injected at deploy time via
# GitHub Actions secrets — the .env file is never present on the server.
# =============================================================================

# -----------------------------------------------------------------------------
# Catalog — PostgreSQL (catalog-db container)
# -----------------------------------------------------------------------------

# Database superuser created at first container startup.
POSTGRES_USER=catalog_user

# Change this in production. Use a long random string (e.g. openssl rand -hex 32).
POSTGRES_PASSWORD=catalog_dev_password

# Database name created at first container startup.
POSTGRES_DB=catalog_db

# -----------------------------------------------------------------------------
# Catalog — Service (catalog container)
# -----------------------------------------------------------------------------

# Controls log format (JSON in production, pretty-printed in development).
# Values: development | production
NODE_ENV=development

# Minimum log level emitted by Pino.
# Values: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Users — PostgreSQL (users-db container)
# -----------------------------------------------------------------------------

USERS_POSTGRES_USER=users_user
USERS_POSTGRES_PASSWORD=users_dev_password
USERS_POSTGRES_DB=users_db

# -----------------------------------------------------------------------------
# Orders — PostgreSQL (orders-db container)
# -----------------------------------------------------------------------------

ORDERS_POSTGRES_USER=orders_user
ORDERS_POSTGRES_PASSWORD=orders_dev_password
ORDERS_POSTGRES_DB=orders_db

# -----------------------------------------------------------------------------
# Payments — PostgreSQL (payments-db container)
# -----------------------------------------------------------------------------

PAYMENTS_POSTGRES_USER=payments_user
PAYMENTS_POSTGRES_PASSWORD=payments_dev_password
PAYMENTS_POSTGRES_DB=payments_db
